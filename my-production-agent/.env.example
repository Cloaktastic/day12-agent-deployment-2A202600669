# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App Metadata
APP_NAME="Production AI Agent"
APP_VERSION="1.0.0"

# LLM Configuration
# Set your OpenAI API key here to enable the real LLM, otherwise mock LLM is used.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security Settings
AGENT_API_KEY=dev-key-change-me
JWT_SECRET=dev-jwt-secret
ALLOWED_ORIGINS=*

# Redis Config
REDIS_URL=redis://localhost:6379/0

# Gatekeeper Settings
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
